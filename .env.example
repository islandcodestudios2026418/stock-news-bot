# Stock News Bot — Environment Variables
# Copy to .env and fill in your values

# Web server port (default: 8080)
PORT=8080

# Discord webhook for alerts (get from Discord channel settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Optional: separate webhook for CRITICAL-only alerts
DISCORD_CRITICAL_WEBHOOK_URL=
